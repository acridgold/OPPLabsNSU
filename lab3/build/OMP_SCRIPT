#!/bin/bash
#PBS -N SLAU_FULL_REPORT
#PBS -l nodes=1:ppn=12
#PBS -l walltime=00:40:00
#PBS -j oe

cd $PBS_O_WORKDIR
g++ -O3 -fopenmp gen.cpp -o generate
g++ -O3 -fopenmp -march=native ../src/omp.cpp -o omp_prog

RESULT_FILE="RESULT.txt"
CSV_FILE="bench_results.csv"

echo "=== BENCHMARK START: $(date) ===" > $RESULT_FILE
echo "CPU Info: $(lscpu | grep 'Model name' | cut -d: -f2 | xargs)" >> $RESULT_FILE
echo "Threads,Time" > $CSV_FILE

echo "Generating matrix..." >> $RESULT_FILE
./generate >> $RESULT_FILE 2>&1

echo "=== Запуск замеров производительности ===" >> $RESULT_FILE

THREADS_LIST="1 2 4 8 12 16 20 24"

for t in $THREADS_LIST
do
    echo "Running with $t threads..."

    echo -e "\n>>> TEST RUN: THREADS = $t <<<" >> $RESULT_FILE
    echo "----------------------------------------" >> $RESULT_FILE

    export OMP_NUM_THREADS=$t
    export OMP_PROC_BIND=false

    OUTPUT=$(./omp_prog)
    echo "$OUTPUT" >> $RESULT_FILE

    TIME=$(echo "$OUTPUT" | grep "Time:" | awk '{print $2}' | sed 's/s//')
    echo "$t,$TIME" >> $CSV_FILE

    echo "----------------------------------------" >> $RESULT_FILE
    echo "Done for $t threads. Time: $TIME s"