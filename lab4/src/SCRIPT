#!/bin/bash
#PBS -N MatMul_MPI_2D
#PBS -l nodes=2:ppn=12
#PBS -l walltime=03:00:00
#PBS -j oe

cd $PBS_O_WORKDIR

# ══════════════════════════════════════════════════════════════════════════════
# Компиляция (-O1 чтобы последовательная версия давала ~30 сек)
# ══════════════════════════════════════════════════════════════════════════════
echo "=== Компиляция ==="
mpiicpc ../src/mpi_prog.cpp   -o mpi_matmul     -O0 -std=c++11
icpc    ../src/sequential.cpp -o sequential     -O0
mpecxx -mpilog ../src/mpi_prog.cpp -o mpi_matmul_mpe -O0 -std=c++11
echo "Компиляция завершена."

# ── Размеры матриц ────────────────────────────────────────────────────────────
# Квадратная матрица N×N×N (ТЗ: квадратная, но программа работает с любыми).
# N должно делиться на все p1, p2 из {1,2,3,4,6,8,12} → lcm=24 → N=2400
# n2=2800 (n2 — внутренняя размерность, делимость не нужна):
#   при -O1 даёт последовательной ~30 сек.
N=3120
N2=2800

# ══════════════════════════════════════════════════════════════════════════════
# БЛОК 1: Последовательный запуск  (квадратная матрица N×N2×N)
# ══════════════════════════════════════════════════════════════════════════════
echo ""
echo "════════════════════════════════════════════════════════════"
echo "  БЛОК 1: Последовательный запуск"
echo "  A[${N}x${N2}] x B[${N2}x${N}]  (квадратная C[${N}x${N}])"
echo "════════════════════════════════════════════════════════════"

./sequential $N $N2 $N | tee sequential.txt

T_SEQ=$(grep "t_sequential" sequential.txt | awk '{print $3}')
echo "Последовательное время: ${T_SEQ} с"

# ══════════════════════════════════════════════════════════════════════════════
# БЛОК 2: Влияние формы решетки при 24 процессах (квадратная матрица)
#
# Все решетки произведения = 24, матрица одна и та же → видим как
# форма решетки (соотношение p1:p2) влияет на время.
# Квадратная решетка (≈4x6) ожидаемо даёт минимум времени.
# ══════════════════════════════════════════════════════════════════════════════
echo ""
echo "════════════════════════════════════════════════════════════"
echo "  БЛОК 2: Влияние формы решетки (24 процесса)"
echo "  A[${N}x${N2}] x B[${N2}x${N}]"
echo "════════════════════════════════════════════════════════════"

declare -A GRIDS
GRIDS["2x12"]="2 12"
GRIDS["3x8"]="3 8"
GRIDS["4x6"]="4 6"
GRIDS["6x4"]="6 4"
GRIDS["8x3"]="8 3"
GRIDS["12x2"]="12 2"

for GNAME in "2x12" "3x8" "4x6" "6x4" "8x3" "12x2"; do
    read P1 P2 <<< "${GRIDS[$GNAME]}"
    echo ""
    echo "--- Решетка ${GNAME} ---"
    mpirun -machinefile $PBS_NODEFILE -np 24 -perhost 12 \
        ./mpi_matmul $P1 $P2 $N $N2 $N \
        > result_grid_${GNAME}.txt 2>&1
    cat result_grid_${GNAME}.txt
done

echo ""
echo "--- Сводная таблица: влияние формы решетки (24 процесса) ---"
printf "%-8s | %-13s | %-12s\n" "Решетка" "t_compute (s)" "t_total (s)"
printf -- "---------|---------------|-------------\n"
for GNAME in "2x12" "3x8" "4x6" "6x4" "8x3" "12x2"; do
    TC=$(grep "t_compute" result_grid_${GNAME}.txt | awk '{print $3}')
    TT=$(grep "t_total"   result_grid_${GNAME}.txt | awk '{print $3}')
    printf "%-8s | %-13s | %-12s\n" "$GNAME" "${TC:--}" "${TT:--}"
done

# ══════════════════════════════════════════════════════════════════════════════
# БЛОК 3: Ускорение и эффективность от числа процессов
#
# Используем наиболее квадратную решетку для каждого NP.
# Ожидаемый результат — "график корыта":
#   - Ускорение S = T_seq / T_parallel растёт, но медленнее NP
#   - Эффективность E = S / NP монотонно падает с ростом NP
#   - Видно как накладные расходы (коммуникации) "съедают" прирост
# ══════════════════════════════════════════════════════════════════════════════
echo ""
echo "════════════════════════════════════════════════════════════"
echo "  БЛОК 3: Ускорение и эффективность"
echo "  A[${N}x${N2}] x B[${N2}x${N}]"
echo "════════════════════════════════════════════════════════════"

# Формат: "NP P1 P2"  — наиболее квадратная решетка для каждого NP
CONFIGS=(
    "1  1  1"
    "2  1  2"
    "4  2  2"
    "6  2  3"
    "8  2  4"
    "12 3  4"
    "16 4  4"
    "24 4  6"
)

for CFG in "${CONFIGS[@]}"; do
    read NP P1 P2 <<< "$CFG"
    echo ""
    echo "--- ${NP} процессов, решетка ${P1}x${P2} ---"
    if [ "$NP" -eq 1 ]; then
        mpirun -machinefile $PBS_NODEFILE -np 1 \
            ./mpi_matmul 1 1 $N $N2 $N \
            > result_np${NP}.txt 2>&1
    elif [ "$NP" -le 12 ]; then
        mpirun -machinefile $PBS_NODEFILE -np $NP \
            ./mpi_matmul $P1 $P2 $N $N2 $N \
            > result_np${NP}.txt 2>&1
    else
        mpirun -machinefile $PBS_NODEFILE -np $NP -perhost 12 \
            ./mpi_matmul $P1 $P2 $N $N2 $N \
            > result_np${NP}.txt 2>&1
    fi
    cat result_np${NP}.txt
done

echo ""
echo "--- Таблица ускорения и эффективности ---"
printf "%-4s | %-8s | %-13s | %-12s | %-11s | %-11s\n" \
    "NP" "Решетка" "t_compute (s)" "t_total (s)" "Ускорение S" "Эффект. E"
printf -- "-----|----------|---------------|--------------|-------------|------------\n"

for CFG in "${CONFIGS[@]}"; do
    read NP P1 P2 <<< "$CFG"
    TC=$(grep "t_compute" result_np${NP}.txt | awk '{print $3}')
    TT=$(grep "t_total"   result_np${NP}.txt | awk '{print $3}')
    if [ -n "$TC" ] && [ -n "$T_SEQ" ]; then
        S=$(awk "BEGIN{printf \"%.4f\", ${T_SEQ}/${TC}}")
        E=$(awk "BEGIN{printf \"%.4f\", ${S}/${NP}}")
    else
        S="-"; E="-"
    fi
    printf "%-4s | %-8s | %-13s | %-12s | %-11s | %-11s\n" \
        "$NP" "${P1}x${P2}" "${TC:--}" "${TT:--}" "$S" "$E"
done

# ══════════════════════════════════════════════════════════════════════════════
# БЛОК 4: Профилирование с MPE (-mpilog), 8 процессов
# ══════════════════════════════════════════════════════════════════════════════
echo ""
echo "════════════════════════════════════════════════════════════"
echo "  БЛОК 4: Профилирование с MPE (-mpilog), 8 процессов"
echo "  A[${N}x${N2}] x B[${N2}x${N}]"
echo "  → генерируется .clog2 для jumpshot"
echo "════════════════════════════════════════════════════════════"

for GNAME in "2x4" "4x2"; do
    P1=$(echo $GNAME | cut -d'x' -f1)
    P2=$(echo $GNAME | cut -d'x' -f2)
    echo ""
    echo "--- Профилирование решетка ${GNAME} ---"
    mpirun -machinefile $PBS_NODEFILE -np 8 \
        ./mpi_matmul_mpe $P1 $P2 $N $N2 $N \
        > profile_${GNAME}.txt 2>&1
    cat profile_${GNAME}.txt

    TC=$(grep "t_compute" profile_${GNAME}.txt | awk '{print $3}')
    if [ -n "$TC" ] && [ -n "$T_SEQ" ]; then
        S=$(awk "BEGIN{printf \"%.4f\", ${T_SEQ}/${TC}}")
        E=$(awk "BEGIN{printf \"%.4f\", ${S}/8}")
        echo "  Ускорение S = ${S},  Эффективность E = ${E}"
    fi

    if [ -f mpi_matmul_mpe.clog2 ]; then
        mv mpi_matmul_mpe.clog2 profile_${GNAME}.clog2
        echo "  Лог: profile_${GNAME}.clog2"
    fi
done

echo ""
echo "=== Готово ==="
echo "Просмотр: jumpshot profile_2x4.clog2"